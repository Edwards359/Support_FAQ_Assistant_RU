OPENAI_API_KEY=sk-...
PORT=8080
# Максимальная длина текста вопроса (символы). Снижает расход токенов и злоупотребления.
MAX_INPUT_CHARS=2000
# Верхняя граница длины ответа модели (токены). Для лаконичных ответов поддержки обычно 400–700.
MAX_OUTPUT_TOKENS=512
# JWT (опционально): если REQUIRE_AUTH=true, запросы к /chat/support требуют Bearer-токен HS256.
REQUIRE_AUTH=false
JWT_SECRET=change-me
